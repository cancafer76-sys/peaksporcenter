{
  "name": "peakspor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "build": "vite build && node scripts/generate-sitemap.mjs",
    "prestart": "node -e \"if(!process.env.RAILWAY_ENVIRONMENT&&process.env.NODE_ENV!=='production'){const fs=require('fs');if(!fs.existsSync('.env')&&fs.existsSync('.env.example'))fs.copyFileSync('.env.example','.env')}\"",
    "start": "node server/index.js",
    "start:local": "npm run build && npm run db:push && node server/index.js",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push --skip-generate"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@vitejs/plugin-react": "^4.5.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.525.0",
    "multer": "^2.0.2",
    "prisma": "^6.11.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "sharp": "^0.35.2",
    "vite": "^7.0.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10"
  }
}
