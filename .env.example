# Local development (SQLite)
DATABASE_URL="file:./dev.db"

# Production Railway (PostgreSQL) — schema provider must be postgresql on deploy
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/railway

# Admin panel login (Railway Variables sekmesine ekleyin)
ADMIN_EMAIL=cancafer76@gmail.com
ADMIN_PASSWORD=your-secure-password

# Security
JWT_SECRET=change-this-to-a-long-random-string
NODE_ENV=production

# Optional
PORT=3001
COOKIE_SECURE=true

# Local development (PostgreSQL gerekir - Railway Postgres public URL kullanabilirsiniz)
# DATABASE_URL=postgresql://...
