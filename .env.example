# PostgreSQL — Railway Postgres servisinden DATABASE_URL otomatik gelir
# Yerel geliştirme için Railway Postgres > Connect > Public URL kopyalayın
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/railway

# Admin panel girişi (Railway Variables sekmesine ekleyin)
ADMIN_EMAIL=cancafer76@gmail.com
ADMIN_PASSWORD=your-secure-password

# Güvenlik
JWT_SECRET=change-this-to-a-long-random-string
NODE_ENV=production
COOKIE_SECURE=true

# Railway PORT otomatik atanır; Networking'de seçtiğiniz port ile eşleşir (3000 veya 8080)
# PORT=8080

# Google Analytics 4 (opsiyonel — yoksa analytics yüklenmez)
# Railway build öncesi VITE_ önekli değişken olarak ekleyin
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
